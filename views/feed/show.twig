{% extends "layouts/app.twig" %}

{% block content %}
	<div class="max-w-2xl mx-auto mt-10">

		<article class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-8">

			<a href="/profile/show?id={{ post.user_id }}" class="flex items-center space-x-2 hover:opacity-80 transition-opacity" >
				<div class="flex items-center mb-4">
					<img src="/images/{{ post.user.profile_picture }}" class="w-12 h-12 rounded-full object-cover border border-gray-300">
					<div class="ml-3">
						<p class="font-semibold text-gray-800">{{ post.user.username }}</p>
						<p class="text-sm text-gray-500">@{{ post.user.username }}</p>
					</div>
				</div>
			</a>


			<div class="bg-gray-900 text-gray-100 rounded-lg p-4 overflow-x-auto font-mono text-sm leading-relaxed mb-4">
				<pre><code class="language-{{ post.language }}">{{ post.code }}</code></pre>
			</div>

			<p class="text-gray-700 mb-4">{{ post.caption }}</p>

			<div class="flex items-center justify-between mt-4">
				<div class="flex items-center gap-2">
					<a href="/feed/toggle?post_id={{ post.id }}" class="{{ userLiked ? 'text-red-500' : 'text-gray-400' }} hover:text-red-500 transition text-xl">❤️</a>
					<span class="text-gray-600">{{ likes }}
						likes</span>
				</div>
			</div>

		</article>

		<section class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">

			<h3 class="text-xl font-semibold text-gray-800 mb-4">Comments</h3>

			{% if comments|length == 0 %}
				<p class="text-gray-500">Nog geen comments…</p>
			{% endif %}

			<div class="space-y-4 mb-6">
				{% for c in comments %}
					<div class="border-b border-gray-200 pb-3">
						<div class="flex items-center gap-3 mb-1">
							<img src="/images/{{ c.user.profile_picture }}" class="w-8 h-8 rounded-full object-cover border border-gray-300">
							<p class="font-medium text-gray-800">{{ c.user.username }}</p>
						</div>
						<p class="text-gray-700 ml-11">{{ c.text }}</p>
					</div>
				{% endfor %}
			</div>

			<form method="post" action="/feed/comment" class="space-y-4">
				<input type="hidden" name="post_id" value="{{ post.id }}">

				<textarea name="text" rows="3" class="w-full border border-gray-300 rounded-lg p-3 focus:ring focus:ring-blue-200" placeholder="Schrijf een comment…"></textarea>

				<button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
					Comment plaatsen
				</button>
			</form>

		</section>

	</div>
{% endblock %}
