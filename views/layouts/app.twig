<!DOCTYPE html>
<html lang="nl">
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Mijn site
			{% endblock %}
		</title>
		<link href="/css/app.css" rel="stylesheet">
		<link href="https://cdnjs.cloudflare.com/ajax/libs/prism-themes/1.9.0/prism-vsc-dark-plus.min.css" rel="stylesheet"/>
		<link rel="icon" type="image/x-icon" href="/images/logo3.jpg">
	</head>
	<body class="bg-gray-100 min-h-screen">

		<nav
			class="bg-white border-b border-gray-200 px-6 py-2 flex items-center justify-between">
			<!-- Left: Logo -->
			<div class="flex items-center">
				<a href="/" class="text-2xl italic font-serif text-gray-800">Binsta</a>
			</div>

			<!-- Center: Search -->
			<div class="flex-1 max-w-md mx-6">
				<form action="/feed/search" method="get" class="relative">
					<span class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
						<svg class="w-4 h-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-3.5-3.5M17 10a7 7 0 11-14 0 7 7 0 0114 0z"/>
						</svg>
					</span>
					<input type="search" name="q" placeholder="Search" class="w-full pl-9 pr-3 py-2 rounded-md bg-gray-100 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-300"/>
				</form>
			</div>

			<!-- Right: Icons + Profile -->
			<div class="flex items-center space-x-5">
				<a href="/" class="text-gray-700 hover:text-gray-900">
					<svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewbox="0 0 24 24">
						<path d="M3 9.75L12 3l9 6.75V21a.75.75 0 01-.75.75H3.75A.75.75 0 013 21V9.75z"/>
					</svg>
				</a>
				<a href="/feed/create" class="text-gray-700 hover:text-gray-900">
					<svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
					</svg>
				</a>

				{% if session.user_id %}
					<div class="flex items-center space-x-2">
						<a href="/profile/show?id={{ session.user_id }}" class="flex items-center space-x-2 hover:opacity-80 transition-opacity">
							<img src="/images/{{ session.profile_picture }}" alt="{{ session.username }}" class="w-8 h-8 rounded-full object-cover">
							<p class="text-gray-700 text-sm">Welcome,
								{{ session.username }}</p>
						</a>
						<a href="/user/logout" class="text-gray-500 hover:text-gray-700 text-sm">Logout</a>
					</div>
				{% else %}
					<a href="/user/login" class="text-gray-700 hover:text-gray-900 text-sm">Login</a>
				{% endif %}
			</div>
		</nav>


		{% block content %}{% endblock %}

		<!-- 1. Core only (not the full bundle) -->
		<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js"></script>
		<!-- 2. Autoloader handles all languages automatically -->
		<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>


	</body>
</html>
